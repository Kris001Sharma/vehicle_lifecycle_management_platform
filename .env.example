# Supabase
VITE_SUPABASE_URL=           # Your Supabase project URL
VITE_SUPABASE_ANON_KEY=      # Supabase anon/public key (safe to expose)
# Never put SUPABASE_SERVICE_ROLE_KEY in a VITE_ variable.
# Service role key is used only in Cloudflare Workers and
# Supabase Edge Functions where it is set as a secret.

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=  # Your Cloudinary cloud name
# Cloudinary API key and secret are never in VITE_ variables.
# Set them only in Supabase Edge Function secrets.

# R2
VITE_R2_PUBLIC_DOMAIN=       # Custom domain for serving R2 files
# R2 access key and secret are never in VITE_ variables.
# Set them only in Cloudflare Worker secrets.

# App
VITE_APP_NAME=               # Display name shown in UI and PWA manifest
